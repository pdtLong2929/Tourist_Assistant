###############################################################################
#  Tourist Assistant — Environment Variables
#  Copy this file to .env and fill in your values.
#
#    cp .env.example .env
#
###############################################################################

# ─── PostgreSQL ──────────────────────────────────────────────────────────
POSTGRES_USER=tourist
POSTGRES_PASSWORD=tourist_secret
POSTGRES_DB=tourist_assistant
POSTGRES_PORT=5432

# ─── MongoDB ─────────────────────────────────────────────────────────────
MONGO_USER=tourist
MONGO_PASSWORD=tourist_secret
MONGO_DB=tourist_assistant
MONGO_PORT=27017

# ─── Next.js App ─────────────────────────────────────────────────────────
APP_PORT=3000

# ─── pgAdmin (Postgres Web UI) ──────────────────────────────────────────
PGADMIN_EMAIL=admin@tourist.dev
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# ─── Mongo Express (MongoDB Web UI) ─────────────────────────────────────
MONGO_EXPRESS_PORT=8081
